<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvDialogItemName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Item name"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvDialogItemStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status: Available"
            android:layout_marginBottom="12dp" />

        <RadioGroup
            android:id="@+id/rgAction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <RadioButton
                android:id="@+id/rbCheckout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Checkout" />

            <RadioButton
                android:id="@+id/rbReturn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Return"
                android:layout_marginStart="24dp" />
        </RadioGroup>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Holder email"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etHolder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textEmailAddress"
            android:hint="person@example.com"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Due date (YYYY-MM-DD)"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etDueDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="date"
            android:hint="2025-12-01"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvDialogNote"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="For returns, holder and due date are ignored."
            android:textSize="12sp"
            android:layout_marginTop="4dp" />

    </LinearLayout>
</ScrollView>
