<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".ManualCheckoutReturnActivity">

    <TextView
        android:id="@+id/tvManualTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Manual Check Out / Return"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvManualSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Search for an item, then tap it to check out or return."
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/etManualSearch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Search by name or ID"
        android:imeOptions="actionDone"
        android:inputType="text"
        android:layout_marginBottom="8dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvManualInventory"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        tools:listitem="@layout/item_inventory" />

</LinearLayout>
